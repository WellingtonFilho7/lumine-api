{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/bootstrap",
      "dest": "/api/bootstrap.js"
    },
    {
      "src": "/api/admin/internal-users/pending",
      "dest": "/api/admin/internal-users/pending.js"
    },
    {
      "src": "/api/admin/internal-users/approve",
      "dest": "/api/admin/internal-users/approve.js"
    },
    {
      "src": "/api/children/create",
      "dest": "/api/children/create.js"
    },
    {
      "src": "/api/children/update",
      "dest": "/api/children/update.js"
    },
    {
      "src": "/api/children/delete",
      "dest": "/api/children/delete.js"
    },
    {
      "src": "/api/records/upsert",
      "dest": "/api/records/upsert.js"
    },
    {
      "src": "/api/finance/create",
      "dest": "/api/finance/create.js"
    },
    {
      "src": "/api/finance/list",
      "dest": "/api/finance/list.js"
    },
    {
      "src": "/api/finance/upload-url",
      "dest": "/api/finance/upload-url.js"
    },
    {
      "src": "/api/finance/file-url",
      "dest": "/api/finance/file-url.js"
    },
    {
      "src": "/api/sync",
      "dest": "/api/sync.js"
    },
    {
      "src": "/api/intake/pre-cadastro",
      "dest": "/api/intake/pre-cadastro.js"
    },
    {
      "src": "/api/intake/triagem",
      "dest": "/api/intake/triagem.js"
    },
    {
      "src": "/api/intake/matricula",
      "dest": "/api/intake/matricula.js"
    }
  ]
}
